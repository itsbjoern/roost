  "author": "Björn Friedrichs (https://bjoernf.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsbjoern/roost.git"
  },
  "bugs": {
    "url": "https://github.com/itsbjoern/roost/issues"
  },
  "homepage": "https://github.com/itsbjoern/roost#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
