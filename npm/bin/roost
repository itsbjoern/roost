#!/usr/bin/env node

const { platform, arch } = process;
const { spawn } = require("node:child_process");

const PLATFORMS = {
  win32: {
    x64: "@itsbjoern/roost-win32-x64/roost.exe",
    arm64: null,
  },
  darwin: {
    x64: null,
    arm64: "@itsbjoern/roost-darwin-arm64/roost",
  },
  linux: {
    x64: "@itsbjoern/roost-linux-x64/roost",
    arm64: null,
  },
};

const binPath = PLATFORMS[platform]?.[arch] ?? null;

function run(binaryPath) {
  const child = spawn(binaryPath, process.argv.slice(2), {
    stdio: ["inherit", "pipe", "pipe"],
    shell: false,
  });
  child.stdout.pipe(process.stdout);
  child.stderr.pipe(process.stderr);
  child.on("close", (code, signal) => {
    process.exitCode = code != null ? code : signal ? 128 + signal : 1;
  });
}

if (binPath) {
  try {
    run(require.resolve(binPath));
  } catch {
    console.error(
      "roost: binary not found for this platform.\n" +
        "Install a prebuilt binary or build from source:\n" +
        "  https://github.com/itsbjoern/roost#install",
    );
    process.exit(1);
  }
} else {
  console.error(
    "roost: binary not found for this platform.\n" +
      "Install a prebuilt binary or build from source:\n" +
      "  https://github.com/itsbjoern/roost#install",
  );
  process.exit(1);
}
